{
  "name": "hookpm",
  "version": "0.1.0",
  "description": "CLI package manager for Claude Code hooks — install, remove, search, and publish hooks from the hookpm registry",
  "keywords": [
    "claude",
    "claude-code",
    "hooks",
    "mcp",
    "cli",
    "package-manager",
    "hookpm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nafistiham/hook-marketplace.git"
  },
  "homepage": "https://hookpm.dev",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hookpm": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc --build tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@hookpm/schema": "workspace:*",
    "cac": "^6.7.14",
    "tar": "^7.5.11",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/tar": "^7.0.87",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
