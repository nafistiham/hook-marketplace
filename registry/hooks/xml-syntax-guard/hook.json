{
  "name": "xml-syntax-guard",
  "version": "1.0.0",
  "description": "Validates XML/SVG/XHTML syntax before writing. Uses Python's built-in xml.etree.ElementTree to parse content and blocks with the exact parse error if malformed. Pure stdlib, no external dependencies.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^(Write|Edit)$"
  },
  "handler": {
    "type": "command",
    "command": "python3 linter.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["xml", "svg", "syntax", "validation"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": false
  },
  "requires": {
    "os": ["darwin", "linux", "windows"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
