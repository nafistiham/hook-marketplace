{
  "name": "debug-artifact-guard",
  "version": "1.0.0",
  "description": "Blocks writes containing debug artifacts across multiple languages: debugger statements (JS/TS), pdb.set_trace/breakpoint (Python), binding.pry/byebug (Ruby), dd/dump/var_dump (PHP). Reports line numbers and what was found. Skips test files.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^(Write|Edit)$"
  },
  "handler": {
    "type": "command",
    "command": "python3 guard.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["debugging", "code-quality", "safety"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": false
  },
  "requires": {
    "os": ["darwin", "linux", "windows"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
