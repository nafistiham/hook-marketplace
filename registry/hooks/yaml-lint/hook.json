{
  "name": "yaml-lint",
  "version": "1.0.0",
  "description": "Validates YAML syntax before writing .yml/.yaml files. Uses Python's built-in yaml module (PyYAML) to parse the content and blocks with a descriptive error message and line number if a syntax error is found. No external dependencies beyond PyYAML.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^(Write|Edit)$"
  },
  "handler": {
    "type": "command",
    "command": "python3 linter.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["yaml", "syntax", "validation"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": false
  },
  "requires": {
    "os": ["darwin", "linux", "windows"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
