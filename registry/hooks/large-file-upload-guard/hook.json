{
  "name": "large-file-upload-guard",
  "version": "1.0.0",
  "description": "Blocks writing files larger than 5MB to prevent accidentally committing binaries, compiled artifacts, or data dumps into the repository.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^Write$"
  },
  "handler": {
    "type": "command",
    "command": "python3 guard.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["safety", "files", "repository", "size"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": false
  },
  "requires": {
    "os": ["darwin", "linux", "windows"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
