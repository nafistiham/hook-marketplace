{
  "name": "git-commit-lint",
  "version": "1.0.0",
  "description": "Blocks git commit commands that don't follow Conventional Commits format (type(scope): description). Catches bad commit messages before they're written, keeping history clean.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^Bash$"
  },
  "handler": {
    "type": "command",
    "command": "python3 guard.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["git", "commits", "conventional-commits", "code-quality"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": false
  },
  "requires": {
    "os": ["darwin", "linux", "windows"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
