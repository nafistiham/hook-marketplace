{
  "name": "dockerfile-lint",
  "version": "1.0.0",
  "description": "Lints Dockerfile content before writing. Checks for common Dockerfile anti-patterns: running as root, using latest tag, no HEALTHCHECK, ADD instead of COPY, multiple RUN commands that should be chained, and exposed dangerous ports.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^(Write|Edit)$"
  },
  "handler": {
    "type": "command",
    "command": "python3 linter.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["docker", "containers", "linting", "devops", "security"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": false
  },
  "requires": {
    "os": ["darwin", "linux", "windows"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
