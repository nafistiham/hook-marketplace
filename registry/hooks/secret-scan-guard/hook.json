{
  "name": "secret-scan-guard",
  "version": "1.0.0",
  "description": "Scans files for hardcoded secrets before writing — AWS keys, GitHub tokens, Stripe keys, private keys, generic high-entropy strings. Blocks the write if a credential pattern is found. Uses gitleaks if installed, falls back to built-in regex patterns.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^(Write|Edit)$"
  },
  "handler": {
    "type": "command",
    "command": "python3 guard.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["security", "secrets", "credentials", "scanning", "owasp"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": true
  },
  "requires": {
    "os": ["darwin", "linux"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
