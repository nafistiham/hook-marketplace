{
  "name": "long-line-guard",
  "version": "1.0.0",
  "description": "Warns when code files contain lines over 120 characters. Shows the count of long lines and up to 3 worst offenders with line number and length. Skips minified, generated, and markdown files.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^(Write|Edit)$"
  },
  "handler": {
    "type": "command",
    "command": "python3 guard.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["code-quality", "formatting", "readability"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": false
  },
  "requires": {
    "os": ["darwin", "linux"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
