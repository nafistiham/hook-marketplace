{
  "name": "dockerfile-secrets-guard",
  "version": "1.0.0",
  "description": "Blocks secrets baked into Dockerfiles via ENV instructions with secret-looking names (*_KEY, *_SECRET, *_TOKEN, *_PASSWORD, DATABASE_URL). Warns on ARG instructions with the same naming patterns.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^(Write|Edit)$"
  },
  "handler": {
    "type": "command",
    "command": "python3 guard.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["docker", "security", "secrets", "devops"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": false
  },
  "requires": {
    "os": ["darwin", "linux"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
