{
  "name": "shellcheck-guard",
  "version": "1.0.0",
  "description": "Runs ShellCheck on shell scripts before writing. Catches common shell scripting errors, unquoted variables, unsafe patterns, and portability issues. Requires shellcheck to be installed (brew install shellcheck).",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^(Write|Edit)$"
  },
  "handler": {
    "type": "command",
    "command": "python3 guard.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["shell", "bash", "shellcheck", "linting", "safety"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": true
  },
  "requires": {
    "os": ["darwin", "linux"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
