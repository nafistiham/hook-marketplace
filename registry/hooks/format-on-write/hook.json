{
  "name": "format-on-write",
  "version": "1.0.0",
  "description": "Automatically formats files after Claude Code writes them. Detects the formatter based on file extension (prettier for JS/TS/JSON, black for Python, gofmt for Go).",
  "author": "hookpm",
  "license": "MIT",
  "event": "PostToolUse",
  "matcher": {
    "tool_name": "^(Write|Edit|NotebookEdit)$"
  },
  "handler": {
    "type": "command",
    "command": "python3 format.py",
    "async": true
  },
  "capabilities": ["side-effects-only"],
  "tags": ["formatting", "developer-experience", "python", "javascript", "typescript", "go"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": ["PATH"],
    "spawns_processes": true
  },
  "requires": {
    "os": ["darwin", "linux"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
