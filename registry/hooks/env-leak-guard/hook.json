{
  "name": "env-leak-guard",
  "version": "1.0.0",
  "description": "Intercepts Bash commands that reference common secret patterns (API_KEY, SECRET, TOKEN, PASSWORD, PRIVATE_KEY) and blocks or warns before they run, preventing accidental credential leakage.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^Bash$"
  },
  "handler": {
    "type": "command",
    "command": "python3 guard.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["security", "secrets", "environment", "bash"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": false
  },
  "requires": {
    "os": ["darwin", "linux"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
