{
  "name": "semgrep-guard",
  "version": "1.0.0",
  "description": "Runs Semgrep security analysis on code before it is written. Uses the auto ruleset which detects OWASP Top 10 vulnerabilities, injection flaws, and language-specific anti-patterns. Requires semgrep to be installed.",
  "author": "hookpm",
  "license": "MIT",
  "event": "PreToolUse",
  "matcher": {
    "tool_name": "^(Write|Edit)$"
  },
  "handler": {
    "type": "command",
    "command": "python3 guard.py",
    "async": false
  },
  "capabilities": ["block"],
  "tags": ["security", "semgrep", "sast", "owasp", "static-analysis"],
  "permissions": {
    "network": { "allowed": false, "domains": [] },
    "filesystem": { "read": [], "write": [] },
    "env_vars": [],
    "spawns_processes": true
  },
  "requires": {
    "os": ["darwin", "linux"],
    "shell": ["bash", "zsh", "sh"]
  },
  "security": {
    "sandbox_level": "static-analysis",
    "reviewed": false,
    "review_date": null,
    "signed": false,
    "signed_by": null,
    "signature": null
  }
}
